{
  "_meta": {
    "description": "Dark mode overrides for semantic color tokens",
    "scheme": "dark",
    "wcag": {
      "level": "AA",
      "notes": [
        "interactive tokens shift to lighter shades (4-6) so buttons read against neutral-11 dark surface",
        "color-text-on-primary flips to neutral-12 — dark text on lighter dark-mode button fills",
        "tinted backgrounds use shade 10; badge/card text uses interactive-active (shade 2) for ~4.5:1 on those surfaces",
        "color-text-warning uses yellow-2 (not yellow-3) to meet 4.5:1 on yellow-10 tinted surface",
        "disabled states remain exempt from contrast requirements per WCAG 1.4.3"
      ]
    }
  },

  "semantic": {
    "color": {
      "background": {
        "--color-background-default":     "hsl(var(--neutral-11-hsl))",
        "--color-background-subtle":      "hsl(var(--neutral-10-hsl))",
        "--color-background-raised":      "hsl(var(--neutral-9-hsl))",
        "--color-background-sunken":      "hsl(var(--neutral-12-hsl))",
        "--color-background-overlay":     "hsl(var(--neutral-12-hsl) / 0.75)",
        "--color-background-inverse":     "hsl(var(--neutral-0-hsl))",
        "--color-background-disabled":    "hsl(var(--neutral-9-hsl))",
        "--color-background-primary":     "hsl(var(--indigo-10-hsl))",
        "--color-background-danger":      "hsl(var(--red-10-hsl))",
        "--color-background-success":     "hsl(var(--green-10-hsl))",
        "--color-background-warning":     "hsl(var(--yellow-10-hsl))",
        "--color-background-information": "hsl(var(--blue-10-hsl))"
      },

      "text": {
        "--color-text-primary":      "hsl(var(--neutral-0-hsl))",
        "--color-text-secondary":    "hsl(var(--neutral-3-hsl))",
        "--color-text-tertiary":     "hsl(var(--neutral-5-hsl))",
        "--color-text-placeholder":  "hsl(var(--neutral-6-hsl))",
        "--color-text-disabled":     "hsl(var(--neutral-7-hsl))",
        "--color-text-inverse":      "hsl(var(--neutral-12-hsl))",
        "--color-text-on-primary":   "hsl(var(--neutral-12-hsl))",
        "--color-text-link":         "hsl(var(--indigo-3-hsl))",
        "--color-text-link-hover":   "hsl(var(--indigo-2-hsl))",
        "--color-text-danger":       "hsl(var(--red-3-hsl))",
        "--color-text-success":      "hsl(var(--green-3-hsl))",
        "--color-text-warning":      "hsl(var(--yellow-2-hsl))",
        "--color-text-information":  "hsl(var(--blue-3-hsl))"
      },

      "border": {
        "--color-border-subtle":            "hsl(var(--neutral-9-hsl))",
        "--color-border-default":           "hsl(var(--neutral-8-hsl))",
        "--color-border-strong":            "hsl(var(--neutral-6-hsl))",
        "--color-border-disabled":          "hsl(var(--neutral-9-hsl))",
        "--color-border-focus":             "hsl(var(--indigo-5-hsl))",
        "--color-border-danger":            "hsl(var(--red-5-hsl))",
        "--color-border-success":           "hsl(var(--green-5-hsl))",
        "--color-border-warning":           "hsl(var(--yellow-5-hsl))",
        "--color-border-information":       "hsl(var(--blue-5-hsl))",

        "--color-border-primary-subtle":    "hsl(var(--indigo-8-hsl))",
        "--color-border-danger-subtle":     "hsl(var(--red-8-hsl))",
        "--color-border-success-subtle":    "hsl(var(--green-7-hsl))",
        "--color-border-information-subtle":"hsl(var(--blue-8-hsl))",

        "--color-border-control":           "hsl(var(--neutral-7-hsl))",
        "--color-border-input":             "hsl(var(--neutral-8-hsl))"
      },

      "interactive": {
        "--color-interactive-primary-default":    "hsl(var(--indigo-5-hsl))",
        "--color-interactive-primary-hover":      "hsl(var(--indigo-4-hsl))",
        "--color-interactive-primary-active":     "hsl(var(--indigo-2-hsl))",
        "--color-interactive-primary-focus-ring": "hsl(var(--indigo-9-hsl))",

        "--color-interactive-danger-default":    "hsl(var(--red-6-hsl))",
        "--color-interactive-danger-hover":      "hsl(var(--red-5-hsl))",
        "--color-interactive-danger-active":     "hsl(var(--red-2-hsl))",
        "--color-interactive-danger-focus-ring": "hsl(var(--red-9-hsl))",

        "--color-interactive-warning-default":    "hsl(var(--yellow-5-hsl))",
        "--color-interactive-warning-hover":      "hsl(var(--yellow-4-hsl))",
        "--color-interactive-warning-active":     "hsl(var(--yellow-2-hsl))",
        "--color-interactive-warning-focus-ring": "hsl(var(--yellow-9-hsl))",

        "--color-interactive-success-default":    "hsl(var(--green-5-hsl))",
        "--color-interactive-success-hover":      "hsl(var(--green-4-hsl))",
        "--color-interactive-success-active":     "hsl(var(--green-2-hsl))",
        "--color-interactive-success-focus-ring": "hsl(var(--green-9-hsl))",

        "--color-interactive-information-default":    "hsl(var(--blue-5-hsl))",
        "--color-interactive-information-hover":      "hsl(var(--blue-4-hsl))",
        "--color-interactive-information-active":     "hsl(var(--blue-2-hsl))",
        "--color-interactive-information-focus-ring": "hsl(var(--blue-9-hsl))",

        "--color-interactive-neutral-default":    "hsl(var(--neutral-4-hsl))",
        "--color-interactive-neutral-hover":      "hsl(var(--neutral-3-hsl))",
        "--color-interactive-neutral-active":     "hsl(var(--neutral-1-hsl))",
        "--color-interactive-neutral-focus-ring": "hsl(var(--neutral-8-hsl))"
      }
    }
  }
}
